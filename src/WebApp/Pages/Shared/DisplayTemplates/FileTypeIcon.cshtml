@model string
@{
    var icon = Model.ToLowerInvariant() switch
    {
        ".txt" => "file-icon-text",
        ".rtf" => "file-icon-rtf",
        ".csv" => "file-icon-csv",
        ".xls" or ".xlsx" => "file-icon-excel",
        ".doc" or ".docx" => "file-icon-word",
        ".pdf" => "file-icon-pdf",
        ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".svg" => "file-icon-image",
        ".html" or ".htm" => "file-icon-html",
        ".ppt" or ".pptx" => "file-icon-powerpoint",
        _ => "file-icon-default",
    };
}
<svg class="bi svg-icon" role="img">
    <use href="@Url.Content("~/images/file-type-icons.svg?20260421")#@icon"></use>
</svg>
